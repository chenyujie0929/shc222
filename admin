// ── File drag & drop (UI only, actual upload via Drive) ──
function handleFileSelect(input) {
  if (!input.files.length) return;
  const f = input.files[0];
  showFileItem(f);
  document.getElementById('dl-name').value = f.name.replace(/\.[^.]+$/,'');
}

function handleFileDrop(e) {
  e.preventDefault();
  document.getElementById('file-drop').classList.remove('dragging');
  const f = e.dataTransfer.files[0];
  if (f) { showFileItem(f); document.getElementById('dl-name').value = f.name.replace(/\.[^.]+$/,''); }
}

function showFileItem(f) {
  const ext = f.name.split('.').pop().toUpperCase();
  const size = f.size > 1048576 ? (f.size/1048576).toFixed(1)+'MB' : Math.round(f.size/1024)+'KB';
  const icons = { PDF:'📄', DOC:'📝', DOCX:'📝', XLS:'📊', XLSX:'📊' };
  document.getElementById('file-list').innerHTML = `
    <div class="file-item">
      <span class="file-item-icon">${icons[ext]||'📎'}</span>
      <span class="file-item-name">${f.name}</span>
      <span class="file-item-size">${size}</span>
      <span class="badge badge-gold">${ext}</span>
    </div>
    <div style="font-size:.75rem;color:var(--t-light);padding:.5rem 0;line-height:1.7;">
      💡 請手動將此檔案上傳至 Google Drive，取得共用連結後貼入「連結」欄位
    </div>`;
}

