<script>
// ═══════════════════════════════════════
//  CONFIG & STATE
// ═══════════════════════════════════════
const CREDS = { user: 'admin', passHash: 'eb65f9ada2224e11ed7507a6645bab8c19c2a781a89081ba96eddbf61f39eae2' }; // 密碼已 SHA-256，可在設定頁修改

let API_URL   = localStorage.getItem('shc_api')   || '';
let API_TOKEN = localStorage.getItem('shc_token') || 'SHC-01FBC3DEBF4240001533DBC4025388BC';
let newsData = [];
let dirAllData = [];
let dlAllData = [];

// ═══════════════════════════════════════
//  AUTH
// ═══════════════════════════════════════
// SHA-256 hash 工具
async function sha256(str) {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
}

async function doLogin() {
  const u = document.getElementById('login-user').value.trim();
  const p = document.getElementById('login-pass').value;
  const err = document.getElementById('auth-error');

  const savedUser = localStorage.getItem('shc_user') || CREDS.user;
  // 比對 hash（若 localStorage 存的是 hash；首次登入用明文比對後轉存 hash）
  const savedHash = localStorage.getItem('shc_pass_hash');
  const inputHash = await sha256(p);

  let passOk = false;
  if (savedHash) {
    // 已有 hash：直接比對 hash
    passOk = (inputHash === savedHash);
  } else {
    // 第一次：用明文比對（預設密碼）
    const defaultPass = 'shc2026';
    passOk = (p === defaultPass);
    if (passOk) {
      // 轉存 hash，下次就不用明文了
      localStorage.setItem('shc_pass_hash', await sha256(defaultPass));
      localStorage.removeItem('shc_pass'); // 移除舊明文
    }
  }

  if (u === savedUser && passOk) {
    err.style.display = 'none';
    document.getElementById('auth-screen').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    document.getElementById('topbar-user').textContent = u;
    loadSettings();
    loadDashboard();
  } else {
    err.style.display = 'block';
    document.getElementById('login-pass').value = '';
    document.getElementById('login-pass').focus();
