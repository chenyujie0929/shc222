
<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>後台管理 — 四季豐收驗證有限公司</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600&family=Noto+Sans+TC:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════════
   VARIABLES
══════════════════════════════════════════ */
:root {
  --g-deep:   #2d5a3d;
  --g-mid:    #4a7c5e;
  --g-light:  #7aab8a;
  --g-pale:   #b8d4be;
  --g-wash:   #edf7f2;
  --gold:     #c4963a;
  --gold-w:   #faf5e8;
  --sky:      #e4f0f5;
  --sky-mid:  #8fc0d4;
  --cream:    #fbfaf7;
  --white:    #ffffff;
  --t-dark:   #2c3e2d;
  --t-mid:    #5a6b5b;
  --t-light:  #9aaa9a;
  --border:   rgba(180,210,190,.4);
  --shadow:   0 2px 16px rgba(45,90,61,.08);
  --shadow-lg:0 8px 32px rgba(45,90,61,.14);
  --r:        12px;
  --sidebar:  240px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{font-size:15px;}
body{
  font-family:'Noto Sans TC',sans-serif;
  background:var(--cream);color:var(--t-dark);
  overflow-x:hidden;
}
a{text-decoration:none;color:inherit;}
button{border:none;cursor:pointer;font-family:inherit;}
input,textarea,select{font-family:inherit;}

/* ══════════════════════════════════════════
   AUTH SCREEN
══════════════════════════════════════════ */
#auth-screen {
  min-height:100vh;
  display:flex;align-items:stretch;
  position:relative;overflow:hidden;
}

/* 左側品牌面板 */
.auth-brand-panel {
  width:420px;flex-shrink:0;
  background:linear-gradient(160deg,#2d5a3d 0%,#3a7a5a 45%,#4a7c3a 100%);
  display:flex;flex-direction:column;
  justify-content:space-between;
  padding:3rem 3.2rem;
  position:relative;overflow:hidden;
}
.auth-brand-panel::before {
  content:'';position:absolute;
  top:-80px;right:-80px;
  width:300px;height:300px;border-radius:50%;
  background:radial-gradient(circle,rgba(196,150,58,.2) 0%,transparent 70%);
}
.auth-brand-panel::after {
  content:'';position:absolute;
  bottom:-60px;left:-60px;
  width:240px;height:240px;border-radius:50%;
  background:radial-gradient(circle,rgba(143,192,212,.15) 0%,transparent 70%);
}
.auth-brand-logo {
  position:relative;z-index:1;
}
.auth-brand-logo img {
  height:56px;width:auto;object-fit:contain;
  filter:brightness(0) invert(1);
  opacity:.92;
  margin-bottom:1.4rem;
  display:block;
}
.auth-brand-name {
  font-family:'Noto Serif TC',serif;
  font-size:1.3rem;font-weight:500;
  color:white;line-height:1.5;
  margin-bottom:.5rem;
}
.auth-brand-en {
  font-size:.72rem;letter-spacing:.18em;
  color:rgba(255,255,255,.5);
  text-transform:uppercase;
}
.auth-brand-quote {
  position:relative;z-index:1;
}
.auth-brand-quote p {
  font-family:'Noto Serif TC',serif;
  font-size:.9rem;color:rgba(255,255,255,.75);
  line-height:2;
  border-left:2px solid rgba(196,150,58,.6);
  padding-left:1rem;
}
.auth-brand-footer {
  position:relative;z-index:1;
  font-size:.7rem;color:rgba(255,255,255,.35);
  letter-spacing:.06em;
}

/* 右側登入面板 */
.auth-form-panel {
  flex:1;
  display:flex;align-items:center;justify-content:center;
  background:linear-gradient(145deg,#f4faf7 0%,#f0f8fb 50%,#fdf9f2 100%);
  padding:2rem;
}
.auth-card {
  background:white;border-radius:20px;
  box-shadow:0 8px 40px rgba(45,90,61,.1);
  padding:2.8rem 3rem;width:380px;
  position:relative;z-index:1;
  border:1px solid var(--border);
}
.auth-card-tag {
  display:inline-block;
  font-size:.68rem;letter-spacing:.18em;
  color:var(--g-mid);background:var(--g-wash);
  border-radius:16px;padding:.25rem .9rem;
  margin-bottom:1.4rem;
}
.auth-title {
  font-family:'Noto Serif TC',serif;
  font-size:1.6rem;font-weight:500;
  color:var(--g-deep);margin-bottom:.3rem;
  line-height:1.3;
}
.auth-sub {
  font-size:.82rem;color:var(--t-light);margin-bottom:2rem;
}
.auth-field {margin-bottom:1.1rem;}
.auth-label {
  display:block;font-size:.72rem;letter-spacing:.1em;
  color:var(--t-mid);margin-bottom:.4rem;
}
.auth-input {
  width:100%;padding:.75rem 1rem;
  border:1.5px solid var(--border);border-radius:10px;
  font-size:.88rem;color:var(--t-dark);background:#f8faf8;
  transition:.2s;outline:none;
}
.auth-input:focus {
  border-color:var(--g-light);
  box-shadow:0 0 0 3px rgba(122,171,138,.15);
  background:white;
}
.auth-btn {
  width:100%;padding:.88rem;
  background:linear-gradient(135deg,#2d5a3d,#3a7a5a);
  color:white;border-radius:12px;font-size:.9rem;
  letter-spacing:.06em;transition:all .25s;margin-top:.8rem;
  font-family:'Noto Sans TC',sans-serif;
}
.auth-btn:hover{
  background:linear-gradient(135deg,#3a7a5a,#4a8a6a);
  transform:translateY(-1px);
  box-shadow:0 6px 20px rgba(45,90,61,.2);
}
.auth-error {
  background:#fff0f0;border:1px solid #f5c0c0;
  border-radius:8px;padding:.7rem 1rem;
  font-size:.8rem;color:#c0392b;margin-bottom:1rem;display:none;
}
.auth-hint {
  font-size:.7rem;color:var(--t-light);
  text-align:center;margin-top:1.2rem;
  line-height:1.7;
}
/* 隱藏舊版 auth-logo（品牌面板已取代） */
.auth-logo { display:none; }

@media(max-width:800px){
  #auth-screen { flex-direction:column; }
  .auth-brand-panel { width:100%; padding:2rem; min-height:200px; }
  .auth-brand-quote { display:none; }
  .auth-form-panel { padding:1.5rem; }
  .auth-card { width:100%; padding:2rem; }
}

/* ══════════════════════════════════════════
   MAIN APP LAYOUT
══════════════════════════════════════════ */
#app { display:none; min-height:100vh; }

/* SIDEBAR */
.sidebar {
  position:fixed;top:0;left:0;bottom:0;
  width:var(--sidebar);
  background:linear-gradient(175deg,#f0f8fb,#edf7f2,#fdf8ef);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  z-index:100;transition:.3s;
}
.sidebar-logo {
  padding:1.5rem 1.4rem;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:8px;
}
.sidebar-logo-text {
  font-family:'Noto Serif TC',serif;
  font-size:.78rem;font-weight:500;
  color:var(--g-deep);line-height:1.4;
}
.sidebar-section {
  font-size:.65rem;letter-spacing:.18em;
  color:var(--t-light);padding:.9rem 1.4rem .3rem;
}
.sidebar-nav {flex:1;padding:.5rem 0;overflow-y:auto;}
.nav-item {
  display:flex;align-items:center;gap:.7rem;
  padding:.65rem 1.4rem;font-size:.83rem;
  color:var(--t-mid);cursor:pointer;transition:.2s;
  border-radius:0;margin:0 .5rem;border-radius:8px;
}
.nav-item:hover{background:rgba(74,124,94,.08);color:var(--g-deep);}
.nav-item.active{
  background:linear-gradient(135deg,rgba(74,124,94,.15),rgba(143,192,212,.1));
  color:var(--g-deep);font-weight:500;
}
.nav-item .nav-icon{font-size:1rem;width:22px;text-align:center;}
.sidebar-footer {
  padding:1rem 1.4rem;border-top:1px solid var(--border);
}
.logout-btn {
  display:flex;align-items:center;gap:.6rem;
  font-size:.8rem;color:var(--t-light);
  cursor:pointer;padding:.5rem .6rem;border-radius:8px;transition:.2s;
  width:100%;
}
.logout-btn:hover{color:var(--g-deep);background:rgba(74,124,94,.06);}

/* MAIN CONTENT */
.main-content {
  margin-left:var(--sidebar);
  min-height:100vh;
  display:flex;flex-direction:column;
}

/* TOPBAR */
.topbar {
  background:white;
  border-bottom:1px solid var(--border);
  padding:0 2rem;
  height:58px;display:flex;
  align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:50;
}
.topbar-title {
  font-family:'Noto Serif TC',serif;
  font-size:1rem;font-weight:500;color:var(--g-deep);
}
.topbar-right {
  display:flex;align-items:center;gap:.8rem;
}
.api-status {
  display:flex;align-items:center;gap:.4rem;
  font-size:.72rem;color:var(--t-light);
}
.api-dot {
  width:7px;height:7px;border-radius:50%;
  background:#e0e0e0;transition:.3s;
}
.api-dot.connected{background:#4caf50;}
.api-dot.error{background:#f44336;}
.topbar-user {
  font-size:.8rem;color:var(--t-mid);
  background:var(--g-wash);border-radius:20px;
  padding:.3rem .9rem;
}

/* PANEL */
.panel{
  flex:1;padding:2rem;
  display:none;
}
.panel.active{display:block;}

/* ══════════════════════════════════════════
   DASHBOARD
══════════════════════════════════════════ */
.dash-grid {
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:1.2rem;margin-bottom:2.5rem;
}
.stat-card {
  background:white;border-radius:var(--r);
  border:1px solid var(--border);box-shadow:var(--shadow);
  padding:1.4rem 1.6rem;
  position:relative;overflow:hidden;
}
.stat-card::before {
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
}
.stat-card:nth-child(1)::before{background:linear-gradient(90deg,var(--sky-mid),var(--g-pale));}
.stat-card:nth-child(2)::before{background:linear-gradient(90deg,var(--g-pale),var(--g-light));}
.stat-card:nth-child(3)::before{background:linear-gradient(90deg,var(--gold),#e8c97a);}
.stat-card:nth-child(4)::before{background:linear-gradient(90deg,var(--g-light),var(--sky-mid));}
.stat-icon{font-size:1.6rem;margin-bottom:.6rem;}
.stat-num{
  font-family:'Noto Serif TC',serif;font-size:1.8rem;
  font-weight:500;color:var(--g-deep);line-height:1;
}
.stat-label{font-size:.75rem;color:var(--t-light);margin-top:.3rem;}

.dash-recent {
  background:white;border-radius:var(--r);
  border:1px solid var(--border);box-shadow:var(--shadow);
  overflow:hidden;
}
.panel-head {
  display:flex;align-items:center;justify-content:space-between;
  padding:1.2rem 1.6rem;border-bottom:1px solid var(--border);
}
.panel-head h3 {
  font-family:'Noto Serif TC',serif;font-size:.95rem;
  font-weight:500;color:var(--g-deep);
}

/* ══════════════════════════════════════════
   SHARED TABLE
══════════════════════════════════════════ */
.data-table {
  width:100%;border-collapse:collapse;font-size:.83rem;
}
.data-table th {
  background:linear-gradient(90deg,#e8f4f0,#e4f0f5);
  color:var(--g-deep);font-weight:500;
  font-size:.72rem;letter-spacing:.1em;
  padding:.75rem 1.2rem;text-align:left;
  border-bottom:1px solid var(--border);
}
.data-table td {
  padding:.75rem 1.2rem;color:var(--t-mid);
  border-bottom:1px dashed rgba(184,212,190,.3);
  vertical-align:middle;
}
.data-table tr:last-child td{border:none;}
.data-table tr:hover td{background:#f8fdf9;}

/* ══════════════════════════════════════════
   FORM PANEL
══════════════════════════════════════════ */
.form-panel {
  background:white;border-radius:var(--r);
  border:1px solid var(--border);box-shadow:var(--shadow);
  overflow:hidden;margin-bottom:1.5rem;
}
.form-panel-head {
  padding:1.2rem 1.8rem;
  background:linear-gradient(135deg,var(--g-wash),var(--sky));
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.form-panel-head h3 {
  font-family:'Noto Serif TC',serif;font-size:.95rem;
  font-weight:500;color:var(--g-deep);
}
.form-panel-body{padding:1.8rem 2rem;}
.form-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;}
.form-group{margin-bottom:1.2rem;}
.form-label{
  display:block;font-size:.72rem;letter-spacing:.1em;
  color:var(--t-mid);margin-bottom:.4rem;
}
.form-label span{color:#c0392b;}
.form-control{
  width:100%;padding:.65rem .9rem;
  border:1.5px solid var(--border);border-radius:8px;
  font-size:.85rem;color:var(--t-dark);background:var(--cream);
  transition:.2s;outline:none;
}
.form-control:focus{
  border-color:var(--g-light);
  box-shadow:0 0 0 3px rgba(122,171,138,.12);
  background:white;
}
textarea.form-control{min-height:100px;resize:vertical;}
.form-hint{font-size:.7rem;color:var(--t-light);margin-top:.3rem;}
.tag-select{
  display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.3rem;
}
.tag-opt{
  padding:.3rem .8rem;border-radius:16px;font-size:.75rem;
  border:1.5px solid var(--border);color:var(--t-mid);
  cursor:pointer;transition:.2s;background:white;
}
.tag-opt.selected{
  background:linear-gradient(135deg,var(--g-wash),var(--sky));
  border-color:var(--g-light);color:var(--g-deep);font-weight:500;
}

/* BUTTONS */
.btn{
  display:inline-flex;align-items:center;gap:.4rem;
  padding:.55rem 1.2rem;border-radius:8px;font-size:.82rem;
  transition:all .2s;cursor:pointer;letter-spacing:.03em;
}
.btn-primary{
  background:linear-gradient(135deg,var(--g-deep),var(--g-mid));
  color:white;
}
.btn-primary:hover{opacity:.9;transform:translateY(-1px);}
.btn-secondary{
  background:white;color:var(--g-mid);
  border:1.5px solid var(--border);
}
.btn-secondary:hover{background:var(--g-wash);border-color:var(--g-pale);}
.btn-danger{
  background:#fff5f5;color:#c0392b;
  border:1.5px solid #f5c0c0;
}
.btn-danger:hover{background:#ffe8e8;}
.btn-sm{padding:.35rem .8rem;font-size:.75rem;}
.btn-gold{
  background:linear-gradient(135deg,#f5e8c8,#e8c97a);
  color:#7a5a1a;border:1px solid #e8c97a;
}

/* STATUS BADGES */
.badge{
  display:inline-block;font-size:.68rem;
  border-radius:12px;padding:.15rem .65rem;
  font-weight:500;
}
.badge-green{background:#e8f5e9;color:#2e7d32;}
.badge-gold{background:#fff8e1;color:#f57f17;}
.badge-gray{background:#f0f0f0;color:#666;}
.badge-red{background:#ffebee;color:#c62828;}
.badge-blue{background:#e3f2fd;color:#1565c0;}

/* FILE UPLOAD */
.file-drop{
  border:2px dashed var(--border);border-radius:10px;
  padding:2rem;text-align:center;
  background:var(--g-wash);transition:.2s;cursor:pointer;
}
.file-drop:hover,.file-drop.dragging{
  border-color:var(--g-light);background:#dff0e8;
}
.file-drop-icon{font-size:2rem;margin-bottom:.5rem;}
.file-drop-text{font-size:.83rem;color:var(--t-mid);}
.file-drop-hint{font-size:.72rem;color:var(--t-light);margin-top:.3rem;}
.file-list{margin-top:1rem;}
.file-item{
  display:flex;align-items:center;gap:.8rem;
  padding:.6rem .9rem;background:white;
  border-radius:8px;border:1px solid var(--border);
  margin-bottom:.5rem;font-size:.82rem;
}
.file-item-icon{font-size:1rem;}
.file-item-name{flex:1;color:var(--t-dark);}
.file-item-size{font-size:.72rem;color:var(--t-light);}

/* TOAST */
.toast{
  position:fixed;bottom:2rem;right:2rem;z-index:9999;
  background:white;border-radius:10px;
  box-shadow:0 8px 32px rgba(0,0,0,.15);
  border:1px solid var(--border);
  padding:.9rem 1.4rem;
  display:flex;align-items:center;gap:.7rem;
  font-size:.85rem;color:var(--t-dark);
  transform:translateY(100px);opacity:0;
  transition:all .35s cubic-bezier(.34,1.56,.64,1);
  max-width:320px;
}
.toast.show{transform:translateY(0);opacity:1;}
.toast-icon{font-size:1.1rem;}

/* MODAL */
.modal-overlay{
  position:fixed;inset:0;z-index:500;
  background:rgba(0,0,0,.25);backdrop-filter:blur(4px);
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;transition:.25s;
}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{
  background:white;border-radius:16px;
  box-shadow:0 20px 60px rgba(0,0,0,.2);
  width:520px;max-width:92vw;max-height:85vh;
  overflow-y:auto;
  transform:scale(.95);transition:.25s;
}
.modal-overlay.open .modal{transform:scale(1);}
.modal-head{
  padding:1.4rem 1.8rem;
  background:linear-gradient(135deg,var(--g-wash),var(--sky));
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;
}
.modal-head h3{
  font-family:'Noto Serif TC',serif;font-size:1rem;
  font-weight:500;color:var(--g-deep);
}
.modal-close{
  width:28px;height:28px;border-radius:50%;
  background:rgba(0,0,0,.06);color:var(--t-mid);
  display:flex;align-items:center;justify-content:center;
  font-size:.9rem;cursor:pointer;transition:.2s;
}
.modal-close:hover{background:rgba(0,0,0,.12);}
.modal-body{padding:1.6rem 1.8rem;}
.modal-footer{
  padding:1rem 1.8rem;border-top:1px solid var(--border);
  display:flex;justify-content:flex-end;gap:.7rem;
  position:sticky;bottom:0;background:white;
}

/* CONFIRM DIALOG */
.confirm-text{font-size:.88rem;color:var(--t-mid);line-height:1.8;margin-bottom:.5rem;}
.confirm-subject{font-weight:500;color:var(--t-dark);}

/* LOADING STATE */
.loading-row td{
  text-align:center;padding:2rem;
  color:var(--t-light);font-size:.85rem;
}

/* EMPTY STATE */
.empty-state{
  text-align:center;padding:3rem;
}
.empty-icon{font-size:2.5rem;opacity:.4;margin-bottom:.8rem;}
.empty-text{font-size:.85rem;color:var(--t-light);}

/* ══════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════ */
@media(max-width:900px){
  :root{--sidebar:0px;}
  .sidebar{transform:translateX(-240px);width:240px;}
  .sidebar.open{transform:translateX(0);}
  .main-content{margin-left:0;}
  .topbar{padding:0 1rem;}
  .panel{padding:1.2rem;}
  .dash-grid{grid-template-columns:1fr 1fr;}
  .form-grid-2{grid-template-columns:1fr;}
  .hamburger-btn{display:flex !important;}
}
.hamburger-btn{
  display:none;align-items:center;justify-content:center;
  width:36px;height:36px;border-radius:8px;
  background:var(--g-wash);cursor:pointer;font-size:1rem;
  margin-right:.5rem;
}
</style>
</head>
<body>

<!-- ══════════════════════════════════════════
     AUTH SCREEN
══════════════════════════════════════════ -->
<div id="auth-screen">

  <!-- 左側品牌面板 -->
  <div class="auth-brand-panel">
    <div class="auth-brand-logo">
      <img src="data:image/png;base64," alt="四季豐收">
      <div class="auth-brand-name">四季豐收驗證<br>有限公司</div>
      <div class="auth-brand-en">SHC Certification Ltd.</div>
    </div>
    <div class="auth-brand-quote">
      <p>與土地共生，<br>讓豐收成為一種守護。<br><br>望你順遂，四季豐收。</p>
    </div>
    <div class="auth-brand-footer">後台管理系統 · Admin Panel</div>
  </div>

  <!-- 右側登入面板 -->
  <div class="auth-form-panel">
    <div class="auth-card">
      <div class="auth-card-tag">ADMIN LOGIN</div>
      <div class="auth-title">歡迎回來</div>
      <p class="auth-sub">請輸入您的管理員帳號與密碼</p>
      <div id="auth-error" class="auth-error">帳號或密碼錯誤，請再試一次。</div>
      <div class="auth-field">
        <label class="auth-label">帳號</label>
        <input id="login-user" class="auth-input" type="text" placeholder="admin" autocomplete="username">
      </div>
      <div class="auth-field">
        <label class="auth-label">密碼</label>
        <input id="login-pass" class="auth-input" type="password" placeholder="••••••••" autocomplete="current-password"
          onkeydown="if(event.key==='Enter')doLogin()">
