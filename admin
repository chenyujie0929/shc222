//  API HELPERS
// ═══════════════════════════════════════
async function apiGet(type) {
  if (!API_URL) return getDemoData(type);
  const res = await fetch(`${API_URL}?type=${type}&token=${API_TOKEN}`);
  const data = await res.json();
  if (data.error === 'unauthorized') throw new Error('Token 錯誤，請至設定頁更新');
  return data;
}

async function apiPost(action, data) {
  if (!API_URL) {
    await new Promise(r => setTimeout(r, 600));
    return { success: true };
  }
  const res = await fetch(API_URL, {
    method: 'POST',
    body: JSON.stringify({ action, token: API_TOKEN, ...data })
  });
  return await res.json();
}

function setApiStatus(ok) {
  const dot = document.getElementById('api-dot');
  const txt = document.getElementById('api-status-text');
  if (ok === null) { dot.className = 'api-dot'; txt.textContent = '未連線'; return; }
  dot.className = 'api-dot ' + (ok ? 'connected' : 'error');
  txt.textContent = ok ? '已連線' : '連線失敗';
}

