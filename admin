// ═══════════════════════════════════════
function confirmDelete(type, idx, name) {
  openModal('確認刪除', `
    <p class="confirm-text">確定要刪除以下項目？此操作無法復原。</p>
    <p class="confirm-subject">「${name}」</p>`,
    [
      { label:'取消', cls:'btn-secondary', fn:'closeModal()' },
      { label:'🗑 確認刪除', cls:'btn-danger', fn:`doDelete('${type}',${idx})` }
    ]
  );
}

function doDelete(type, idx) {
  if (type === 'news') { newsData.splice(idx,1); renderNewsList(); }
  if (type === 'dir')  { dirAllData.splice(idx,1); renderDirList(dirAllData); }
  if (type === 'dl')   { dlAllData.splice(idx,1); renderDlList(dlAllData); }
  closeModal();
  showToast('🗑', '已刪除（示範模式：實際刪除需設定 API）');
}

// ═══════════════════════════════════════
//  SETTINGS
// ═══════════════════════════════════════
function loadSettings() {
  document.getElementById('setting-api').value   = localStorage.getItem('shc_api')   || '';
  document.getElementById('setting-token').value = localStorage.getItem('shc_token') || API_TOKEN;
  document.getElementById('setting-user').value  = localStorage.getItem('shc_user')  || 'admin';
  if (API_URL) setApiStatus(true);
}

async function saveSettings() {
  const api   = document.getElementById('setting-api').value.trim();
  const token = document.getElementById('setting-token').value.trim();
  const user  = document.getElementById('setting-user').value.trim();
  const pass  = document.getElementById('setting-pass').value;

  if (api)   { localStorage.setItem('shc_api', api);   API_URL = api; }
  if (token) { localStorage.setItem('shc_token', token); API_TOKEN = token; }
  if (user)  { localStorage.setItem('shc_user', user); }

  if (pass) {
    // ★ 密碼存 SHA-256 hash，不存明文
    const hash = await sha256(pass);
    localStorage.setItem('shc_pass_hash', hash);
    localStorage.removeItem('shc_pass'); // 清掉舊明文
    document.getElementById('setting-pass').value = '';
  }

  showToast('💾', '設定已儲存');
  document.getElementById('topbar-user').textContent = user || 'admin';
  if (api) setApiStatus(true);
}

async function testApiConnection() {
  const api = document.getElementById('setting-api').value.trim();
  const resultEl = document.getElementById('conn-result');
  resultEl.style.display = 'block';
  resultEl.innerHTML = '<span style="color:var(--t-light);">測試中…</span>';
  if (!api) { resultEl.innerHTML = '<span style="color:#c0392b;">⚠️ 請先填入 API 網址</span>'; return; }
  try {
    const t = document.getElementById('setting-token').value.trim() || API_TOKEN;
    const res = await fetch(`${api}?type=news&token=${t}`);
    const data = await res.json();
    if (Array.isArray(data) || data.error) {
      resultEl.innerHTML = '<span style="color:#2e7d32;">✅ 連線成功！API 正常回應</span>';
      setApiStatus(true);
    } else {
      resultEl.innerHTML = '<span style="color:#c0392b;">⚠️ 回應格式異常，請確認部署設定</span>';
      setApiStatus(false);
    }
  } catch(e) {
    resultEl.innerHTML = `<span style="color:#c0392b;">❌ 連線失敗：${e.message}</span>`;
    setApiStatus(false);
  }
}

// ═══════════════════════════════════════
//  MODAL
// ═══════════════════════════════════════
function openModal(title, bodyHtml, btns=[]) {
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-body').innerHTML = bodyHtml;
  document.getElementById('modal-footer').innerHTML = btns.map(b =>
    `<button class="btn ${b.cls}" onclick="${b.fn}">${b.label}</button>`
  ).join('');
  document.getElementById('modal-overlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
}

// ═══════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════
let toastTimer;
function showToast(icon, msg) {
  const t = document.getElementById('toast');
  document.getElementById('toast-icon').textContent = icon;
  document.getElementById('toast-msg').textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
}

// ═══════════════════════════════════════
//  INIT
// ═══════════════════════════════════════
// Load API from localStorage
API_URL = localStorage.getItem('shc_api') || '';
if (!API_URL) setApiStatus(null);
</script>
